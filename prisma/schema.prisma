// WiFi Billing System - Schema for the Kenyan market
// Supports M-Pesa payments, voucher codes, internet packages, session management,
// reseller/agent program, promo codes, support tickets and business settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Package {
  id                String   @id @default(cuid())
  name              String
  priceKES          Int
  durationMinutes   Int
  dataLimitMB       Int // 0 = unlimited
  downloadSpeedMbps Int
  uploadSpeedMbps   Int
  description       String
  popular           Boolean  @default(false)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sessions          Session[]
  vouchers          Voucher[]
  transactions      Transaction[]
}

model Customer {
  id               String        @id @default(cuid())
  phone            String        @unique
  name             String?
  email            String?
  location         String?
  otpCode          String?
  otpExpires       DateTime?
  // Loyalty & rewards
  pointsBalance    Int           @default(0)
  lifetimePoints   Int           @default(0)
  tier             String        @default("bronze") // bronze, silver, gold, platinum
  referralCode     String?       @unique
  createdAt        DateTime      @default(now())
  sessions         Session[]
  transactions     Transaction[]
  tickets          SupportTicket[]
  pointsLedger     PointsTransaction[]
  subscriptions    Subscription[]
  referralsMade    Referral[]    @relation("Referrer")
  referredBy       Referral[]    @relation("Referred")
}

model Session {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id])
  phone           String
  packageName     String
  priceKES        Int
  startTime       DateTime @default(now())
  endTime         DateTime
  durationMinutes Int
  status          String   @default("active") // active, expired, disconnected
  dataUsedMB      Int      @default(0)
  ipAddress       String?
  macAddress      String?
  authMethod      String   @default("mpesa") // mpesa, voucher
  mpesaRef        String?
  promoCode       String?
  discountKES     Int      @default(0)
  siteId          String?
  site            HotspotSite? @relation(fields: [siteId], references: [id])
  extended        Boolean  @default(false)
  createdAt       DateTime @default(now())
  feedback        Feedback?
}

model Voucher {
  id          String    @id @default(cuid())
  code        String    @unique
  packageId   String
  package     Package   @relation(fields: [packageId], references: [id])
  packageName String
  priceKES    Int
  status      String    @default("unused") // unused, used, expired
  batchId     String?
  usedBy      String?
  usedAt      DateTime?
  resellerId  String?
  reseller    Reseller? @relation(fields: [resellerId], references: [id])
  createdAt   DateTime  @default(now())
}

model Transaction {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  phone       String
  amountKES   Int
  packageId   String?
  package     Package?  @relation(fields: [packageId], references: [id])
  packageName String?
  method      String    @default("mpesa") // mpesa, voucher, reseller
  mpesaRef    String?
  status      String    @default("pending") // pending, completed, failed
  promoCode   String?
  discountKES Int       @default(0)
  resellerId  String?
  reseller    Reseller? @relation(fields: [resellerId], references: [id])
  createdAt   DateTime  @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

// Reseller / Agent program — partners who sell vouchers at a commission.
model Reseller {
  id               String        @id @default(cuid())
  phone            String        @unique
  name             String
  businessName     String?
  location         String?
  commissionRate   Float         @default(10) // percentage 0..100
  walletBalanceKES Int           @default(0)
  totalEarnedKES   Int           @default(0)
  totalSalesKES    Int           @default(0)
  status           String        @default("active") // active, suspended
  otpCode          String?
  otpExpires       DateTime?
  createdAt        DateTime      @default(now())
  vouchers         Voucher[]
  transactions     Transaction[]
}

// Promo / discount codes applicable at M-Pesa checkout.
model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String
  discountType  String    // percent, fixed
  discountValue Float
  active        Boolean   @default(true)
  usesCount     Int       @default(0)
  maxUses       Int       @default(0) // 0 = unlimited
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

// Support tickets raised by customers and resolved by admins.
model SupportTicket {
  id           String   @id @default(cuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  phone        String
  customerName String?
  subject      String
  message      String
  category     String   @default("general") // general, billing, connectivity, voucher, other
  priority     String   @default("normal") // low, normal, high, urgent
  status       String   @default("open") // open, in_progress, resolved, closed
  adminReply   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Key/value business settings (business name, M-Pesa paybill, support phone...).
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// Hotspot sites / routers — multi-location network management.
model HotspotSite {
  id          String    @id @default(cuid())
  name        String
  location    String
  routerIp    String?
  maxUsers    Int       @default(50)
  status      String    @default("active") // active, inactive, maintenance
  createdAt   DateTime  @default(now())
  sessions    Session[]
  routerStatus RouterStatus?
}

// Broadcast announcements shown to customers on the portal.
model Announcement {
  id        String    @id @default(cuid())
  title     String
  message   String
  type      String    @default("info") // info, warning, maintenance, promo
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// Customer feedback / ratings left after a session ends.
model Feedback {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id])
  customerId String?
  phone     String
  rating    Int      // 1..5
  comment   String?
  createdAt DateTime @default(now())
}

// --- Round 4: Loyalty, referrals, SMS, network, blacklist, subscriptions ---

// Referral: when a customer signs up using someone's referral code.
model Referral {
  id                 String    @id @default(cuid())
  referrerCustomerId String
  referrer           Customer  @relation("Referrer", fields: [referrerCustomerId], references: [id])
  referredCustomerId String?   @unique
  referred           Customer? @relation("Referred", fields: [referredCustomerId], references: [id])
  referredPhone      String
  status             String    @default("pending") // pending, completed
  rewardPoints       Int       @default(0)
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
}

// Points ledger — every earn / redeem event.
model PointsTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  points     Int      // positive = earn, negative = redeem
  type       String   // earn_purchase, earn_referral, redeem_voucher, admin_adjust
  reason     String
  referenceId String?
  createdAt  DateTime @default(now())
}

// Bulk SMS broadcast (simulated sending).
model SmsBroadcast {
  id            String   @id @default(cuid())
  message       String
  audience      String   // all, active, by_site, by_package
  audienceFilter String  // e.g. siteId or packageName or ""
  recipientCount Int     @default(0)
  status        String   @default("sent") // sent, scheduled
  createdAt     DateTime @default(now())
}

// Live router health per hotspot site (simulated metrics).
model RouterStatus {
  id                String   @id @default(cuid())
  siteId            String   @unique
  site              HotspotSite @relation(fields: [siteId], references: [id])
  status            String   @default("online") // online, warning, offline
  uptimeSeconds     Int      @default(0)
  connectedDevices  Int      @default(0)
  bandwidthInMbps   Float    @default(0)
  bandwidthOutMbps  Float    @default(0)
  cpuUsage          Float    @default(0) // percentage
  memoryUsage       Float    @default(0) // percentage
  updatedAt         DateTime @default(now())
}

// Blacklisted phones — blocked from purchasing.
model Blacklist {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String
  createdAt DateTime @default(now())
}

// Auto-renew subscriptions — recurring packages.
model Subscription {
  id            String    @id @default(cuid())
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  phone         String
  packageId     String
  packageName   String
  priceKES      Int
  status        String    @default("active") // active, paused, cancelled
  nextChargeAt  DateTime
  lastChargedAt DateTime?
  createdAt     DateTime  @default(now())
}
